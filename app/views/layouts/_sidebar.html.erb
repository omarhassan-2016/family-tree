<nav class="sidebar">
  <div class="sidebar-header">
    <div class="logo">🌳</div>
    <h1><%= t('sidebar.title', default: 'Family Tree') %></h1>
  </div>

  <div class="sidebar-nav">
    <div class="search-wrapper" data-controller="search">
      <span class="search-icon">🔍</span>
      <input type="text"
             class="search-input"
             placeholder="Search people..."
             data-search-target="input"
             data-action="input->search#search"
             autocomplete="off">
    </div>
    <div id="search_results"></div>

    <%= link_to root_path, class: "nav-link #{controller_name == 'dashboard' ? 'active' : ''}" do %>
      <span class="icon">📊</span>
      <span><%= t('sidebar.dashboard', default: 'Dashboard') %></span>
    <% end %>

    <%= link_to people_path, class: "nav-link #{controller_name == 'people' ? 'active' : ''}" do %>
      <span class="icon">👥</span>
      <span><%= t('sidebar.people', default: 'People') %></span>
    <% end %>

    <%= link_to new_person_path, class: "nav-link" do %>
      <span class="icon">➕</span>
      <span>Add Person</span>
    <% end %>

    <%= link_to relationship_calculator_path, class: "nav-link #{controller_name == 'relationship_calculator' ? 'active' : ''}" do %>
      <span class="icon">🔗</span>
      <span>Relationships</span>
    <% end %>

    <%= link_to health_path, class: "nav-link #{controller_name == 'health' ? 'active' : ''}" do %>
      <span class="icon">🩺</span>
      <span><%= t('sidebar.tree_health', default: 'Tree Health') %></span>
    <% end %>

    <%= link_to map_path, class: "nav-link #{controller_name == 'map' ? 'active' : ''}" do %>
      <span class="icon">🗺️</span>
      <span><%= t('sidebar.map_view', default: 'Map View') %></span>
    <% end %>
  </div>

  <div class="sidebar-footer">
    <%= link_to new_gedcom_path, class: "nav-link" do %>
      <span class="icon">📥</span>
      <span><%= t('sidebar.import_gedcom', default: 'Import GEDCOM') %></span>
    <% end %>

    <%= link_to export_gedcom_path, class: "nav-link", data: { turbo: false } do %>
      <span class="icon">📤</span>
      <span><%= t('sidebar.export_gedcom', default: 'Export GEDCOM') %></span>
    <% end %>
    
    <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border-glass);">
      <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem; word-break: break-all;">
        <%= t('sidebar.logged_in_as', default: 'Logged in as') %><br>
        <strong style="color: var(--text-primary);"><%= current_user&.email %></strong>
        <span class="badge" style="display: inline-block; background: var(--bg-primary); border: 1px solid var(--border-glass); padding: 0.1rem 0.3rem; margin-top: 0.2rem;"><%= current_user&.role %></span>
      </div>

      <% if current_user&.admin? %>
        <%= link_to users_path, class: "nav-link #{controller_name == 'users' ? 'active' : ''}" do %>
          <span class="icon">👥</span>
          <span><%= t('sidebar.manage_users', default: 'Manage Users') %></span>
        <% end %>
      <% end %>

      <%= button_to logout_path, method: :delete, class: "nav-link", style: "width: 100%; text-align: left; background: none; border: none; cursor: pointer; color: var(--danger);" do %>
        <span class="icon">🚪</span>
        <span><%= t('sidebar.sign_out', default: 'Sign Out') %></span>
      <% end %>

      <div style="margin-top: 1rem; padding-top: 0.5rem; border-top: 1px dashed var(--border-glass); display: flex; justify-content: space-between;">
        <%= button_to "EN", locale_path(locale: :en), method: :patch, class: "btn btn-sm #{I18n.locale == :en ? 'btn-primary' : 'btn-secondary'}", style: "flex: 1; margin-right: 0.25rem; font-size: 0.75rem;" %>
        <%= button_to "عربي", locale_path(locale: :ar), method: :patch, class: "btn btn-sm #{I18n.locale == :ar ? 'btn-primary' : 'btn-secondary'}", style: "flex: 1; margin-left: 0.25rem; font-size: 0.75rem;" %>
      </div>
    </div>
  </div>
</nav>
