<% content_for(:title) { "Login — Family Tree" } %>

<div style="max-width: 400px; margin: 6rem auto; padding: 2rem; background: var(--bg-card); border-radius: var(--radius-lg); border: 1px solid var(--border-glass);">
  <div style="text-align: center; margin-bottom: 2rem;">
    <div style="font-size: 3rem; margin-bottom: 1rem;">🌳</div>
    <h1 style="font-size: 1.5rem; margin-bottom: 0.5rem;">Family Tree Login</h1>
    <p style="color: var(--text-muted); font-size: 0.9rem;">Sign in to access the tree</p>
  </div>

  <%= form_with(url: login_path, local: true) do |f| %>
    <div class="form-group">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, class: "form-input", required: true, autofocus: true %>
    </div>

    <div class="form-group">
      <%= f.label :password, class: "form-label" %>
      <%= f.password_field :password, class: "form-input", required: true %>
    </div>

    <%= f.submit "Sign In", class: "btn btn-primary", style: "width: 100%; justify-content: center; margin-top: 1rem;" %>
  <% end %>
</div>
