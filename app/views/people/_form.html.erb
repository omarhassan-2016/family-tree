<%= form_with(model: person, class: "person-form") do |f| %>
  <% if person.errors.any? %>
    <div class="error-list">
      <h3><%= pluralize(person.errors.count, "error") %> prevented this person from being saved:</h3>
      <ul>
        <% person.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <label class="form-label">Profile Photo</label>
    <div class="avatar-upload-wrapper">
      <% if person.persisted? && person.avatar.attached? %>
        <div class="avatar-preview">
          <%= image_tag person.avatar, class: "avatar-preview-img" %>
        </div>
      <% end %>
      <%= f.file_field :avatar, accept: "image/png,image/jpeg,image/gif,image/webp", class: "form-input" %>
      <p style="color: var(--text-muted); font-size: 0.78rem; margin-top: 0.3rem;">PNG, JPEG, GIF or WebP. Max 5MB.</p>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :first_name, class: "form-label" %>
      <%= f.text_field :first_name, class: "form-input", placeholder: "e.g. John", autofocus: true %>
    </div>
    <div class="form-group">
      <%= f.label :last_name, class: "form-label" %>
      <%= f.text_field :last_name, class: "form-input", placeholder: "e.g. Smith" %>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :maiden_name, class: "form-label" %>
      <%= f.text_field :maiden_name, class: "form-input", placeholder: "Birth surname if changed" %>
    </div>
    <div class="form-group">
      <%= f.label :suffix, class: "form-label" %>
      <%= f.text_field :suffix, class: "form-input", placeholder: "e.g. Jr., III" %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :gender, class: "form-label" %>
    <%= f.select :gender, Person.genders.keys.map { |g| [g.humanize, g] },
        { include_blank: "Select gender" }, class: "form-select" %>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :birth_date, class: "form-label" %>
      <%= f.date_field :birth_date, class: "form-input" %>
    </div>
    <div class="form-group">
      <%= f.label :birth_place, class: "form-label" %>
      <%= f.text_field :birth_place, class: "form-input", placeholder: "e.g. London, England" %>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :death_date, class: "form-label" %>
      <%= f.date_field :death_date, class: "form-input" %>
    </div>
    <div class="form-group">
      <%= f.label :death_place, class: "form-label" %>
      <%= f.text_field :death_place, class: "form-input", placeholder: "e.g. New York, USA" %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :notes, class: "form-label" %>
    <%= f.text_area :notes, class: "form-textarea", placeholder: "Additional notes..." %>
  </div>

  <div class="btn-group">
    <%= f.submit class: "btn btn-primary" %>
    <% if person.persisted? %>
      <%= link_to "Cancel", person_path(person), class: "btn btn-secondary" %>
    <% else %>
      <%= link_to "Cancel", people_path, class: "btn btn-secondary" %>
    <% end %>
  </div>
<% end %>
