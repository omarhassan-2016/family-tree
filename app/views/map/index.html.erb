<% content_for(:title) { "Map View — Family Tree" } %>

<% content_for(:head) do %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<% end %>

<div class="page-header">
  <div>
    <h2>🗺️ Map View</h2>
    <p class="subtitle"><%= @places_count %> locations plotted from your family tree</p>
  </div>
</div>

<div class="card" style="padding: 0; overflow: hidden; border-radius: var(--radius-lg);">
  <div id="map-container"
       data-controller="map"
       data-map-url-value="<%= map_data_path(format: :json) %>"
       style="width: 100%; height: 600px; background: var(--bg-secondary);">
  </div>
</div>

<div class="map-legend" style="margin-top: 1rem; display: flex; gap: 1.5rem; justify-content: center;">
  <div class="legend-item"><span class="legend-dot" style="background: var(--success);"></span> Birth places</div>
  <div class="legend-item"><span class="legend-dot" style="background: var(--danger);"></span> Death places</div>
</div>
